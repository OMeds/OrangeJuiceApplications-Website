<?xml version="1.0" encoding="UTF-8"?>
<!-- Template: run ./deploy/generate-filezilla-site.sh after filling .deploy-credentials.env -->
<FileZilla3 version="3.66.5" platform="*">
	<Servers>
		<Server>
			<Host>FTP_HOST_PLACEHOLDER</Host>
			<Port>FTP_PORT_PLACEHOLDER</Port>
			<Protocol>0</Protocol>
			<Type>0</Type>
			<User>FTP_USER_PLACEHOLDER</User>
			<Pass encoding="base64">FTP_PASS_B64_PLACEHOLDER</Pass>
			<Logontype>1</Logontype>
			<TimezoneOffset>0</TimezoneOffset>
			<PasvMode>MODE_DEFAULT</PasvMode>
			<MaximumMultipleConnections>0</MaximumMultipleConnections>
			<EncodingType>Auto</EncodingType>
			<BypassProxy>0</BypassProxy>
			<Name>Orange Juice Applications — Fasthosts</Name>
			<Comments>After connect: local folder = repo/dist, remote = htdocs (see deploy/DEPLOY.md)</Comments>
			<LocalDir></LocalDir>
			<RemoteDir></RemoteDir>
			<SyncBrowsing>0</SyncBrowsing>
			<DirectoryComparison>0</DirectoryComparison>
		</Server>
	</Servers>
</FileZilla3>
